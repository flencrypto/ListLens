generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOTE: pgvector extension is required for vector embeddings.
// Run: CREATE EXTENSION IF NOT EXISTS vector; in your Postgres instance.
// Migration: ALTER TABLE item_analyses ADD COLUMN embedding vector(1536);

model User {
  id         String   @id @default(cuid())
  clerkId    String   @unique
  email      String   @unique
  name       String?
  avatarUrl  String?
  role       String   @default("user")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  workspaces WorkspaceMember[]
  usageEvents UsageEvent[]
}

model Workspace {
  id           String   @id @default(cuid())
  name         String
  plan         String   @default("free")
  credits      Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  members      WorkspaceMember[]
  items        Item[]
  guardChecks  GuardCheck[]
  payments     Payment[]
  usageEvents  UsageEvent[]
  marketplaceAccounts MarketplaceAccount[]
  measureSessions MeasureSession[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role        String    @default("owner")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([workspaceId, userId])
}

model MarketplaceAccount {
  id                  String    @id @default(cuid())
  workspaceId         String
  marketplace         String
  connectorId         String
  accessToken         String?
  refreshToken        String?
  tokenExpiresAt      DateTime?
  accountName         String?
  accountId           String?
  status              String    @default("disconnected")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  @@unique([workspaceId, marketplace])
}

model Item {
  id          String   @id @default(cuid())
  workspaceId String
  status      String   @default("draft")
  marketplace String?
  lens        String?
  title       String?
  description String?
  category    String?
  condition   String?
  price       Float?
  currency    String   @default("GBP")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  photos      ItemPhoto[]
  analyses    ItemAnalysis[]
  listings    Listing[]
  comparableSales ComparableSale[]
}

model ItemPhoto {
  id           String  @id @default(cuid())
  itemId       String
  url          String
  sortOrder    Int     @default(0)
  isPrimary    Boolean @default(false)
  qualityScore Float?
  createdAt    DateTime @default(now())
  item         Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model ItemAnalysis {
  id           String   @id @default(cuid())
  itemId       String
  lens         String
  rawAiOutput  Json
  attributes   Json
  confidence   Float?
  warnings     String[]
  createdAt    DateTime @default(now())
  item         Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model Listing {
  id                   String    @id @default(cuid())
  itemId               String
  marketplace          String
  marketplaceListingId String?
  status               String    @default("draft")
  payload              Json?
  publishedAt          DateTime?
  exportedAt           DateTime?
  soldAt               DateTime?
  createdAt            DateTime  @default(now())
  item                 Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model ComparableSale {
  id             String   @id @default(cuid())
  itemId         String
  source         String
  title          String
  price          Float
  currency       String   @default("GBP")
  saleDate       DateTime?
  relevanceScore Float?
  createdAt      DateTime @default(now())
  item           Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model GuardCheck {
  id             String   @id @default(cuid())
  workspaceId    String
  marketplace    String?
  url            String?
  lens           String?
  riskLevel      String?
  confidence     Float?
  recommendation String?
  rawAiOutput    Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  findings       GuardFinding[]
  questions      GuardQuestion[]
}

model GuardFinding {
  id           String     @id @default(cuid())
  guardCheckId String
  severity     String
  type         String
  message      String
  guardCheck   GuardCheck @relation(fields: [guardCheckId], references: [id], onDelete: Cascade)
}

model GuardQuestion {
  id             String     @id @default(cuid())
  guardCheckId   String
  questionText   String
  targetEvidence String?
  guardCheck     GuardCheck @relation(fields: [guardCheckId], references: [id], onDelete: Cascade)
}

model Payment {
  id                String    @id @default(cuid())
  workspaceId       String
  stripeCustomerId  String?
  subscriptionId    String?
  plan              String    @default("free")
  status            String    @default("active")
  credits           Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model UsageEvent {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String?
  eventName   String
  metadata    Json?
  createdAt   DateTime @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])
}

model MeasureObject {
  id               String   @id @default(cuid())
  name             String
  description      String?
  markerSizeMm     Float
  markerDictionary String   @default("ARUCO_4X4_50")
  createdAt        DateTime @default(now())
  sessions         MeasureSession[]
}

model MeasureSession {
  id              String         @id @default(cuid())
  workspaceId     String
  measureObjectId String?
  status          String         @default("pending")
  imageUrls       String[]
  result          Json?
  confidence      Float?
  warnings        String[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  workspace       Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  measureObject   MeasureObject? @relation(fields: [measureObjectId], references: [id])
}
