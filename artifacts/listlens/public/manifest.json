{
  "$schema": "https://json.schemastore.org/web-manifest-combined.json",
  "name": "Mr.FLENS · List-LENS",
  "short_name": "List-LENS",
  "description": "AI-powered listing studio and buyer-protection for eBay and Vinted. Photos to listing in under 30 seconds.",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "orientation": "portrait-primary",
  "background_color": "#040a14",
  "theme_color": "#22d3ee",
  "lang": "en-GB",
  "dir": "ltr",
  "categories": ["shopping", "productivity", "finance"],
  "iarc_rating_id": "",
  "icons": [
    {
      "src": "./icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "./icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "./icons/icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "./icons/apple-touch-icon.png",
      "sizes": "180x180",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "./icons/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "./icons/icon-maskable.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "./opengraph.jpg",
      "sizes": "1200x630",
      "type": "image/jpeg",
      "form_factor": "wide",
      "label": "Mr.FLENS · List-LENS — AI resale platform"
    }
  ],
  "shortcuts": [
    {
      "name": "New Studio listing",
      "short_name": "Studio",
      "description": "Start a new AI-powered listing",
      "url": "./studio",
      "icons": [{ "src": "./icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Guard check",
      "short_name": "Guard",
      "description": "Check a listing for fraud risk",
      "url": "./guard",
      "icons": [{ "src": "./icons/icon-192.png", "sizes": "192x192" }]
    }
  ],
  "share_target": {
    "action": "/guard",
    "method": "GET",
    "params": {
      "url": "url",
      "title": "title",
      "text": "text"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+listlens",
      "url": "./?intent=%s"
    }
  ],
  "edge_side_panel": {
    "preferred_width": 480
  },
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "related_applications": [],
  "prefer_related_applications": false
}
