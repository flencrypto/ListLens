{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NODE_ENV",
        "VERCEL_ENV",
        "LISTLENS_ENV",
        "LISTLENS_ALLOW_PLACEHOLDER_CLERK_KEY",
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "type-check": {},
    "typecheck": {},
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
