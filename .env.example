# Database
# In production, point DATABASE_URL at a pooler (e.g. Neon `?pgbouncer=true`,
# Supabase pooler) and DIRECT_URL at the direct connection used by Prisma
# Migrate. For local development, both can be the same URL.
DATABASE_URL=postgresql://postgres:password@localhost:5432/listlens
DIRECT_URL=postgresql://postgres:password@localhost:5432/listlens

# Redis (for BullMQ worker)
REDIS_URL=redis://localhost:6379

# Upstash Redis (rate limiting). Optional: when unset, an in-memory limiter
# is used (single-instance deploys only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OpenAI
OPENAI_API_KEY=sk-...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_STUDIO_STARTER_PRICE_ID=price_...
STRIPE_STUDIO_RESELLER_PRICE_ID=price_...
STRIPE_GUARD_MONTHLY_PRICE_ID=price_...

# eBay Developer Portal (https://developer.ebay.com)
EBAY_APP_ID=...
EBAY_CERT_ID=...
EBAY_DEV_ID=...
EBAY_CLIENT_ID=...
EBAY_CLIENT_SECRET=...
EBAY_ENV=sandbox

# Auth — Choose Clerk OR Supabase (not both)
# Clerk (https://clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Required to verify Clerk → /api/webhooks/clerk for user provisioning.
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Supabase (https://supabase.com) — alternative to Clerk
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...
# SUPABASE_SERVICE_ROLE_KEY=...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Observability
# Sentry — created via `npx @sentry/wizard@latest -i nextjs --saas --org mrflen --project javascript-nextjs`.
SENTRY_DSN=https://...@sentry.io/...
# Public DSN exposed to the browser. Usually identical to SENTRY_DSN.
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# Required for source-map upload at build time. CI / Vercel only — do NOT commit.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=mrflen
SENTRY_PROJECT=javascript-nextjs
POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
AXIOM_TOKEN=
AXIOM_DATASET=listlens

# Build-time toggle: set to "1" in CI/dev to allow `next build` to succeed
# without a real Clerk publishable key. MUST NOT be set in production.
LISTLENS_ALLOW_PLACEHOLDER_CLERK_KEY=
# Set to "production" on real production deploys to reject the placeholder
# Clerk key even if LISTLENS_ALLOW_PLACEHOLDER_CLERK_KEY leaks in.
LISTLENS_ENV=
