# =============================================================================
# ListLens — environment variable template
# =============================================================================
# Copy this file to `apps/web/.env.local` (or repo-root `.env`) and fill in the
# values you have. Every key below has a free-tier source documented in:
#
#     docs/api-keys.md
#
# `.env*` (other than `.env.example`) is gitignored, so your secrets stay local.
# For a zero-key demo, set LISTLENS_ALLOW_PLACEHOLDER_CLERK_KEY=1 and the app
# will boot in demo mode with auth bypassed and mock AI output.
# =============================================================================

# -----------------------------------------------------------------------------
# Database — PostgreSQL (free: local Docker, Neon, Supabase)
# -----------------------------------------------------------------------------
# In production, point DATABASE_URL at a pooler (e.g. Neon `?pgbouncer=true`,
# Supabase pooler) and DIRECT_URL at the direct connection used by Prisma
# Migrate. For local development, both can be the same URL.
DATABASE_URL=postgresql://postgres:password@localhost:5432/listlens
DIRECT_URL=postgresql://postgres:password@localhost:5432/listlens

# -----------------------------------------------------------------------------
# Redis — BullMQ worker (free: local Docker, Upstash 10k cmd/day)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# Upstash Redis (rate limiting). Optional: when unset, an in-memory limiter
# is used (single-instance deploys only). https://upstash.com — free tier.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# OpenAI — Studio & Guard AI (paid; ~$5 trial credits sometimes available)
# https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-REPLACE_ME

# -----------------------------------------------------------------------------
# Stripe — Payments (free in TEST mode; no card needed)
# https://dashboard.stripe.com/test/apikeys
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_STUDIO_STARTER_PRICE_ID=price_REPLACE_ME
STRIPE_STUDIO_RESELLER_PRICE_ID=price_REPLACE_ME
STRIPE_GUARD_MONTHLY_PRICE_ID=price_REPLACE_ME

# -----------------------------------------------------------------------------
# eBay Developer Portal — free (https://developer.ebay.com)
# Create a Sandbox keyset under My Account → Application Keysets.
# -----------------------------------------------------------------------------
EBAY_APP_ID=REPLACE_ME
EBAY_CERT_ID=REPLACE_ME
EBAY_DEV_ID=REPLACE_ME
EBAY_CLIENT_ID=REPLACE_ME
EBAY_CLIENT_SECRET=REPLACE_ME
EBAY_ENV=sandbox

# -----------------------------------------------------------------------------
# Auth — choose Clerk OR Supabase (not both)
# -----------------------------------------------------------------------------
# Clerk — free up to 10k monthly active users (https://clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
# Required to verify Clerk → /api/webhooks/clerk for user provisioning.
CLERK_WEBHOOK_SECRET=whsec_REPLACE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Supabase — alternative to Clerk; free up to 50k MAUs (https://supabase.com)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_ME
# SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
# Sentry — free Developer plan: 5k errors/mo, 10k perf units, 50 replays.
# Created via `npx @sentry/wizard@latest -i nextjs --saas --org mrflen --project javascript-nextjs`.
SENTRY_DSN=https://REPLACE_ME@sentry.io/REPLACE_ME
# Public DSN exposed to the browser. Usually identical to SENTRY_DSN.
NEXT_PUBLIC_SENTRY_DSN=https://REPLACE_ME@sentry.io/REPLACE_ME
# Required for source-map upload at build time. CI / Vercel / Netlify only — do NOT commit.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=mrflen
SENTRY_PROJECT=javascript-nextjs

# PostHog — free: 1M events/mo (https://posthog.com)
POSTHOG_KEY=phc_REPLACE_ME
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Axiom — free: 0.5 TB/mo ingest, 30-day retention (https://axiom.co)
AXIOM_TOKEN=
AXIOM_DATASET=listlens

# -----------------------------------------------------------------------------
# Build-time / runtime flags
# -----------------------------------------------------------------------------
# Set to "1" in CI/dev to allow `next build` to succeed without a real Clerk
# publishable key. MUST NOT be set in production.
LISTLENS_ALLOW_PLACEHOLDER_CLERK_KEY=
# Set to "production" on real production deploys to reject the placeholder
# Clerk key even if LISTLENS_ALLOW_PLACEHOLDER_CLERK_KEY leaks in.
LISTLENS_ENV=
